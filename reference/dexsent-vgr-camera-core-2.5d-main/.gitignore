# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.cache/

# Virtual environments
venv/
.venv/
env/
ENV/

# =========================================================
# IDE / Editor
# =========================================================
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# =========================================================
# OS / System
# =========================================================
.DS_Store
Thumbs.db
ehthumbs.db

# =========================================================
# Logs / Runtime artifacts
# =========================================================
logs/
*.log

# =========================================================
# Local config overrides (DO NOT COMMIT)
# =========================================================
config/*.local.yaml
config/*.local.yml
config/secrets.yaml
config/*.secret.yaml

# =========================================================
# Camera SDK / Vendor Artifacts
# (Never commit SDK binaries or generated files)
# =========================================================
pylon/
spinnaker/
PySpin/
vendor/

# =========================================================
# Shared Memory / IPC Artifacts
# (Should never be in git)
# =========================================================
/dev/shm/
/tmp/
*.shm
*.ipc

# =========================================================
# Build / Packaging
# =========================================================
build/
dist/
*.spec

# =========================================================
# Systemd / Deployment Generated Files
# =========================================================
*.service.local
*.env

# =========================================================
# Jupyter / Experiments (if any)
# =========================================================
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# =========================================================
# Coverage / Reports
# =========================================================
coverage.xml
report.xml

# =========================================================
# Safety Net (optional)
# =========================================================
*.bak
*.old
*.tmp
