{
  "robot": {
    "robot_id": "robot_01",
    "type": "mujoco_ur5e",
    "model_path": "robot_controller/assets/models/ur5e_mjcf/ur5e.xml",
    "home_q": [0.0, -1.57, 1.57, -1.57, -1.57, 0.0],
    "base_frame_yaw_deg": 90.0
  },
  "io": {
    "command_plane": { "mode": "reqrep", "endpoint": "tcp://127.0.0.1:5571" },
